---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import { getTrack, trackTitle } from '../data/tracks';
import { keyFromId, lessonHref, trackHref, readLabel, STR, type Lang } from '../lib/i18n';

interface Props {
  entry: CollectionEntry<'lessons'>;
  lang: Lang;
}

const { entry, lang } = Astro.props;
const { Content } = await render(entry);
const track = getTrack(entry.data.track);
const s = STR[lang];

const siblings = (
  await getCollection(
    'lessons',
    ({ data }) => data.track === entry.data.track && !data.draft && data.lang === lang
  )
).sort((a, b) => a.data.order - b.data.order);
const index = siblings.findIndex((l) => l.id === entry.id);
const prev = siblings[index - 1];
const next = siblings[index + 1];
const key = keyFromId(entry.id);
---

<article data-pagefind-body>
  <header>
    <p class="lesson-eyebrow">
      <a href={trackHref(lang, track.id)}>{trackTitle(track, lang)}</a>
      <span>· {s.lessonOf(entry.data.order, siblings.length)}</span>
    </p>
    <div class="lesson-number" aria-hidden="true">{String(entry.data.order).padStart(2, '0')}</div>
    <h1 class="lesson-title">{entry.data.title}</h1>
    <p class="lesson-desc">{entry.data.description}</p>
    <div class="lesson-meta">
      <span>{readLabel(entry.data.duration, lang)}</span>
      <read-toggle data-id={key} data-mark={s.markRead} data-done={s.markedRead}>
        <button class="read-toggle">{s.markRead}</button>
      </read-toggle>
    </div>
  </header>

  <div class="prose">
    <Content />
  </div>

  <nav class="lesson-pager">
    {
      prev ? (
        <a href={lessonHref(lang, keyFromId(prev.id))}>
          <span class="dir">← {s.pagerPrev}</span>
          {prev.data.title}
        </a>
      ) : (
        <a href={trackHref(lang, track.id)}>
          <span class="dir">← {s.pagerTrack}</span>
          {trackTitle(track, lang)}
        </a>
      )
    }
    {
      next ? (
        <a href={lessonHref(lang, keyFromId(next.id))} style="text-align: right">
          <span class="dir">{s.pagerNext} →</span>
          {next.data.title}
        </a>
      ) : (
        <a href={lang === 'en' ? '/' : '/th/'} style="text-align: right">
          <span class="dir">{s.pagerEnd} →</span>
          {s.pagerBackHome}
        </a>
      )
    }
  </nav>
</article>

<script>
  import { isRead, setRead } from '../lib/progress';

  class ReadToggle extends HTMLElement {
    connectedCallback() {
      const id = this.dataset.id;
      const button = this.querySelector('button');
      const markLabel = this.dataset.mark ?? 'mark as read';
      const doneLabel = this.dataset.done ?? '✓ read';
      if (!id || !button) return;
      const paint = () => {
        const read = isRead(id);
        button.dataset.read = String(read);
        button.textContent = read ? doneLabel : markLabel;
      };
      button.addEventListener('click', () => {
        setRead(id, !isRead(id));
        paint();
      });
      paint();
    }
  }

  if (!customElements.get('read-toggle')) customElements.define('read-toggle', ReadToggle);
</script>
