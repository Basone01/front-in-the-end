---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LessonArticle from '../../components/LessonArticle.astro';
import { keyFromId } from '../../lib/i18n';

export async function getStaticPaths() {
  const all = await getCollection('lessons', ({ data }) => !data.draft);
  const thKeys = new Set(all.filter((l) => l.data.lang === 'th').map((l) => keyFromId(l.id)));
  return all
    .filter((l) => l.data.lang === 'en')
    .map((entry) => ({
      params: { slug: entry.id },
      props: { entry, hasTh: thKeys.has(keyFromId(entry.id)) },
    }));
}

const { entry, hasTh } = Astro.props;
const altHref = hasTh ? `/th/lessons/${keyFromId(entry.id)}/` : undefined;
---

<BaseLayout
  title={`${entry.data.title} · Front in the End`}
  description={entry.data.description}
  lang="en"
  altHref={altHref}
>
  <LessonArticle entry={entry} lang="en" />
</BaseLayout>
