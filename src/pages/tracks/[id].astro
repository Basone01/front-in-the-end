---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrackPage from '../../components/TrackPage.astro';
import { tracks, trackTitle, trackTagline } from '../../data/tracks';

export async function getStaticPaths() {
  return tracks
    .filter((track) => track.status === 'live')
    .map((track) => ({ params: { id: track.id }, props: { track } }));
}

const { track } = Astro.props;
---

<BaseLayout
  title={`${trackTitle(track, 'en')} · Front in the End`}
  description={trackTagline(track, 'en')}
  lang="en"
  altHref={`/th/tracks/${track.id}/`}
>
  <TrackPage trackId={track.id} lang="en" />
</BaseLayout>
