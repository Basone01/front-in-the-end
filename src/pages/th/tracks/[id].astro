---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TrackPage from '../../../components/TrackPage.astro';
import { tracks, trackTitle, trackTagline } from '../../../data/tracks';

export async function getStaticPaths() {
  return tracks
    .filter((track) => track.status === 'live')
    .map((track) => ({ params: { id: track.id }, props: { track } }));
}

const { track } = Astro.props;
---

<BaseLayout
  title={`${trackTitle(track, 'th')} · Front in the End`}
  description={trackTagline(track, 'th')}
  lang="th"
  altHref={`/tracks/${track.id}/`}
>
  <TrackPage trackId={track.id} lang="th" />
</BaseLayout>
