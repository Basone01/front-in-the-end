---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { STR } from '../../lib/i18n';
const s = STR.th;
---

<BaseLayout title="ค้นหา · Front in the End" description="ค้นหาทุกบทเรียน" lang="th" altHref="/search/">
  <section class="hero">
    <h1>{s.searchTitle}</h1>
    <p>{s.searchBlurb}</p>
  </section>

  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <div id="search"></div>
  <script is:inline define:vars={{ unavailable: s.searchUnavailable }}>
    window.addEventListener('DOMContentLoaded', () => {
      if (window.PagefindUI) {
        new window.PagefindUI({ element: '#search', showSubResults: true });
      } else {
        document.getElementById('search').textContent = unavailable;
      }
    });
  </script>
</BaseLayout>
