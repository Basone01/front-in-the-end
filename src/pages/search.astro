---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Search · Front in the End" description="Search all lessons.">
  <section class="hero">
    <h1>Search</h1>
    <p>Every lesson is indexed at build time — no server, no tracking, just Pagefind.</p>
  </section>

  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <div id="search"></div>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      if (window.PagefindUI) {
        new window.PagefindUI({ element: '#search', showSubResults: true });
      } else {
        document.getElementById('search').textContent =
          'Search index not found. It is generated by `npm run build` (Pagefind) and unavailable in dev mode.';
      }
    });
  </script>
</BaseLayout>
